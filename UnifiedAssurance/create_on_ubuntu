#!/bin/bash
set -e

# Configuration Variables
VM_NAME="oracle8-ua-manager"
DISK_SIZE="100G"
BASE_IMAGE_URL="https://yum.oracle.com/templates/OracleLinux/OL8/u10/x86_64/OL8U10_x86_64-kvm-b237.qcow2"
IMAGE_NAME="OL8U10-cloud-base.qcow2"

# Cloud-init file references
USER_DATA="user-data"
META_DATA="meta-data"
NETWORK_DATA="network-config"

echo "--- Step 1: Downloading Oracle Linux 8 Cloud Image ---"
if [ ! -f "$IMAGE_NAME" ]; then
    wget -O "$IMAGE_NAME" "$BASE_IMAGE_URL"
else
    echo "Base image already exists. Skipping download."
fi

echo "--- Step 2: Creating VM Disk and Resizing to $DISK_SIZE ---"
cp "$IMAGE_NAME" "${VM_NAME}.qcow2"
qemu-img resize -f qcow2 "${VM_NAME}.qcow2" $DISK_SIZE

echo "--- Step 3: Generating cloud-init Seed ISO ---"
# Check if all required files exist
for file in "$USER_DATA" "$META_DATA" "$NETWORK_DATA"; do
    if [ ! -f "$file" ]; then
        echo "ERROR: $file is missing!"
        exit 1
    fi
done

# UPDATED: Using -N (uppercase) as per your local help output
cloud-localds -N "$NETWORK_DATA" "${VM_NAME}-seed.iso" "$USER_DATA" "$META_DATA"

echo "--- Success! ---"
echo "Done! Ready to transfer ${VM_NAME}.qcow2 and ${VM_NAME}-seed.iso to Unraid."
