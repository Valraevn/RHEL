#cloud-config
ssh_pwauth: true

users:
  - default
  - name: urmum
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: false
    passwd: 'YOUR_HASHED_PASSWORD_HERE'
    ssh_authorized_keys:
      - ssh-rsa YOUR_SSH_PUBLIC_KEY

growpart:
  mode: auto
  devices: ['/']

package_update: true
packages:
  - qemu-guest-agent
  - wget
  - curl
  - tar
  - net-tools

runcmd:
  - systemctl enable --now qemu-guest-agent
